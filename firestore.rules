rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == "aeazzaoui@gmail.com" ||
        request.auth.token.email == "Aeazzaoui@gmail.com" ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.email == "aeazzaoui@gmail.com")
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidString(val, minLen, maxLen) {
      return val is string && val.size() >= minLen && val.size() <= maxLen;
    }

    function isValidId(id) {
      return id is string && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Rules for User profiles
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isOwner(userId);
    }

    // Rules for Sitter profiles
    match /sitters/{sitterId} {
      allow read: if true; // Publicly searchable
      allow write: if isAdmin() || isOwner(sitterId);
    }

    // Rules for Bookings
    match /bookings/{bookingId} {
      allow read: if isSignedIn(); // Allow reading bookings for signed-in users (filtered by client)
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      allow update: if isSignedIn() && (
        isAdmin() || 
        resource.data.ownerId == request.auth.uid || 
        resource.data.sitterId == request.auth.uid
      );
      allow delete: if isAdmin() || (isSignedIn() && resource.data.ownerId == request.auth.uid);
    }

    // Rules for Messages
    match /messages/{messageId} {
      allow read: if isSignedIn(); // Allow reading messages for signed-in users (filtered by client)
      allow create: if isSignedIn() && request.resource.data.senderId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // Rules for Reviews
    match /reviews/{reviewId} {
      allow read: if true; // Public reviews
      allow create: if isSignedIn() && (
        exists(/databases/$(database)/documents/bookings/$(request.resource.data.bookingId)) &&
        get(/databases/$(database)/documents/bookings/$(request.resource.data.bookingId)).data.ownerId == request.auth.uid &&
        (
          get(/databases/$(database)/documents/bookings/$(request.resource.data.bookingId)).data.status == 'completed' ||
          get(/databases/$(database)/documents/bookings/$(request.resource.data.bookingId)).data.status == 'cancelled'
        )
      );
      allow update, delete: if false; // Reviews are immutable
    }

    // Rules for Notifications
    match /notifications/{notificationId} {
      allow get: if isSignedIn() && isValidId(notificationId) && (
        resource.data.userId == request.auth.uid ||
        resource.data.userId == "all" ||
        (resource.data.userId == "admin" && request.auth.token.email == "aeazzaoui@gmail.com")
      );
      allow list: if isSignedIn();
      allow create: if isSignedIn() && isValidId(notificationId);
      allow update: if isSignedIn() && isValidId(notificationId) && (
        // Allow marking notification as read (only changing the 'read' field)
        (
          (resource.data.userId == request.auth.uid || (resource.data.userId == "admin" && request.auth.token.email == "aeazzaoui@gmail.com")) &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read'])
        ) ||
        // Admin override
        isAdmin()
      );
      allow delete: if isAdmin();
    }

    // Rules for Blog Posts
    match /blogPosts/{postId} {
      allow read: if true; // Anyone can read blog posts
      allow write: if isAdmin(); // Only administrators can create, update, or delete blog posts
    }

    // Rules for Directory
    match /directory/{entryId} {
      allow read: if true; // Publicly readable
      allow write: if isAdmin(); // Only administrators can manage directory entries
    }

    // Rules for Announcements
    match /announcements/{announcementId} {
      allow read: if true; // Publicly readable (filtered on client)
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
    }
  }
}
